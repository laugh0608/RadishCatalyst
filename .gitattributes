# Normalize text files to LF in the repository and working tree.
* text=auto eol=lf

# Source and configuration files.
*.gd text eol=lf
*.cs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.xml text eol=lf
*.csproj text eol=lf
*.fsproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sln text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# Godot text resources.
*.godot text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.res binary
*.scn binary
*.import text eol=lf
*.gdshader text eol=lf

# Scripts.
*.sh text eol=lf
*.ps1 text eol=lf
*.bat text eol=lf
*.cmd text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.bmp binary
*.svg text eol=lf
*.aseprite binary
*.kra binary
*.psd binary
